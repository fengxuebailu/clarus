# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/clarus_db

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# KataGo Configuration
KATAGO_PATH=C:\katago\katago.exe                    # Windows
# KATAGO_PATH=/home/user/katago/katago              # Linux/Mac
KATAGO_CONFIG=C:\katago\analysis_config.cfg
KATAGO_MODEL=C:\katago\kata1-b40c256-s11840935168-d2898845681.bin.gz
KATAGO_TIMEOUT=30

# Application Configuration
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Reconstruction Loop Configuration
MAX_RECONSTRUCTION_RETRIES=3
RECONSTRUCTION_THRESHOLD=0.15
